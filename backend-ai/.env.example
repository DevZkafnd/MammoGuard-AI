HOST=0.0.0.0
PORT=8001
R2_ENDPOINT_URL=https://example-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_NAME=mammoguard-storage
R2_REGION=auto

# Cache lokal (lapisan cache-aside di depan R2)
# Saat dijalankan via Docker, nilai ini di-override ke /app/storage_cache (lihat docker-compose.yml)
STORAGE_CACHE_DIR=./storage_cache
