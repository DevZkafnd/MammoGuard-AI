# App
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=mammoguard_db

# JWT
JWT_SECRET=super_secret_key_min_32_chars_here
JWT_REFRESH_SECRET=another_secret_for_refresh_tokens
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=mgu_rt
COOKIE_SECURE=false

# Bootstrap admin lokal
BOOTSTRAP_ADMIN_NAME=Admin MammoGuard
BOOTSTRAP_ADMIN_EMAIL=admin@mammoguard.id
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
BOOTSTRAP_ADMIN_SPECIALIZATION=System Administrator
