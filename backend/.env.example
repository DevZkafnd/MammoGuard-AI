# Konfigurasi Database MongoDB
MONGODB_URL=mongodb://admin_medis:password_lokal_123@localhost:27017
NAMA_DATABASE=mammoguard_db

# Konfigurasi Model AI
JALUR_MODEL=./storage/models/ResNetDemo_1782708575_9063396e.pth

# Konfigurasi Server
HOST=0.0.0.0
PORT=8000

# Konfigurasi Autentikasi (JWT)
# Generate secret acak: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ganti_dengan_secret_acak_yang_panjang
JWT_EXPIRE_MINUTES=480

# ============================================
# CLOUDFLARE R2 STORAGE CONFIGURATION
# ============================================
# Dapatkan dari: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# Tutorial: https://developers.cloudflare.com/r2/api/s3/tokens/

# Account ID (wajib)
# Contoh: 1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
R2_ACCOUNT_ID=your_account_id_here

# Access Key ID (wajib)
# Contoh: 1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
R2_ACCESS_KEY_ID=your_access_key_id_here

# Secret Access Key (wajib)
# Contoh: abc123def456ghi789jkl012mno345pqr678stu901vwx234yz567
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# Bucket Name
# Default: mammoguard-storage
R2_BUCKET_NAME=mammoguard-storage

# Endpoint URL (auto-generated setelah buat bucket)
# Format: https://<account_id>.r2.cloudflarestorage.com
# Contoh: https://1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# Public URL (opsional, untuk akses publik)
# Jika sudah setup custom domain atau R2.dev subdomain
# Contoh: https://pub-xxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=

# ============================================
# CATATAN PENTING:
# ============================================
# 1. Jangan commit file .env ke Git! (sudah ada di .gitignore)
# 2. R2 GRATIS untuk 10GB storage + 1 juta operasi/bulan
# 3. Jika R2_ACCOUNT_ID kosong, sistem akan pakai local storage
# 4. Untuk production, WAJIB pakai R2 untuk scalability
