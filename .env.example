# =========================================================
# MammoGuard-AI Root Environment Reference
# Dipakai sebagai acuan konfigurasi `docker-compose.yml`,
# `backend-main/.env`, dan `backend-ai/.env`
# =========================================================

# ---------------------------------------------------------
# Shared Infrastructure
# ---------------------------------------------------------
APP_ENV=development
MONGODB_DB_NAME=mammoguard_db

# Cloudflare R2 / S3 Compatible Object Storage
R2_ENDPOINT_URL=https://example-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_NAME=mammoguard-storage
R2_REGION=auto
R2_PUBLIC_BASE_URL=https://cdn.example.com
PRESIGNED_UPLOAD_EXPIRES_SECONDS=900
PRESIGNED_DOWNLOAD_EXPIRES_SECONDS=300

# ---------------------------------------------------------
# backend-main
# ---------------------------------------------------------
BACKEND_MAIN_HOST=0.0.0.0
BACKEND_MAIN_PORT=8000
BACKEND_MAIN_URL=http://localhost:8000
BACKEND_MAIN_CORS_ORIGINS=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017
JWT_SECRET=super_secret_key_min_32_chars_here
JWT_REFRESH_SECRET=another_secret_for_refresh_tokens
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=mgu_rt
COOKIE_SECURE=false
BOOTSTRAP_ADMIN_NAME=Admin MammoGuard
BOOTSTRAP_ADMIN_EMAIL=admin@mammoguard.id
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
BOOTSTRAP_ADMIN_SPECIALIZATION=System Administrator
BACKEND_AI_URL=http://backend-ai:8001
BACKEND_AI_TIMEOUT_SECONDS=60

# ---------------------------------------------------------
# backend-ai
# ---------------------------------------------------------
BACKEND_AI_HOST=0.0.0.0
BACKEND_AI_PORT=8001
BACKEND_AI_PUBLIC_URL=http://localhost:8001

# ---------------------------------------------------------
# Docker Local Network
# ---------------------------------------------------------
DOCKER_MONGODB_HOST=mongodb
DOCKER_BACKEND_MAIN_HOST=backend-main
DOCKER_BACKEND_AI_HOST=backend-ai
