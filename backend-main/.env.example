# App
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=mammoguard_db

# JWT
JWT_SECRET=super_secret_key_min_32_chars_here
JWT_REFRESH_SECRET=another_secret_for_refresh_tokens
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_COOKIE_NAME=mgu_rt
COOKIE_SECURE=false

# Bootstrap admin lokal
BOOTSTRAP_ADMIN_NAME=Admin MammoGuard
BOOTSTRAP_ADMIN_EMAIL=admin@mammoguard.id
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
BOOTSTRAP_ADMIN_SPECIALIZATION=System Administrator

# Cloudflare R2 / S3 Compatible Storage
R2_ENDPOINT_URL=https://example-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-me
R2_SECRET_ACCESS_KEY=replace-me
R2_BUCKET_NAME=mammoguard-storage
R2_REGION=auto
R2_PUBLIC_BASE_URL=https://cdn.example.com
PRESIGNED_UPLOAD_EXPIRES_SECONDS=900
PRESIGNED_DOWNLOAD_EXPIRES_SECONDS=300

# Internal AI backend
BACKEND_AI_URL=http://backend-ai:8001
BACKEND_AI_TIMEOUT_SECONDS=60
